{
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/record-pending-tool.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git *)",
            "command": "~/.claude/hooks/block-git-patterns.sh"
          },
          {
            "type": "command",
            "if": "Bash(rm *)",
            "command": "~/.claude/hooks/block-rm-patterns.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/block-bash-patterns.sh"
          }
        ]
      },
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/pre-exit-plan-mode.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/post-exit-plan-mode.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/record-start-time.sh"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "Plan|Explore",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/set-task-type.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/notify-on-permission.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/notify-on-stop.sh"
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/notify-on-stop-failure.sh"
          }
        ]
      }
    ]
  }
}
