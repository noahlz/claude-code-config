{
  "cleanupPeriodDays": 99999,
  "env": {
    "DISABLE_NON_ESSENTIAL_MODEL_CALLS": "1",
    "ENABLE_LSP_TOOL": "1",
    "CLAUDE_CODE_ENABLE_TASKS": "true",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Read(/Users/noahlz/.claude/plans/**)"
    ]
  },
  "model": "sonnet",
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh",
    "padding": 0
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true,
    "dev-workflow@noahlz.github.io": true,
    "plannotator@plannotator": true,
    "frontend-design@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "playground@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true
  },
  "effortLevel": "medium",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/block-bash-patterns.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/record-start-time.sh"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "Plan|Explore",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/set-task-type.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/say-on-stop.sh"
          }
        ]
      }
    ]
  }
}
